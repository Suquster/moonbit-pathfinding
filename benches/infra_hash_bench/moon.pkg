// Package: benches/infra_hash_bench
//
// 哈希方向基准：加密摘要（SHA-256）吞吐 vs 快速非加密哈希
// （xxHash64 / FNV-1a / CRC32）在同一负载上的相对开销，
// 以及流式 SHA-256 与一次性调用的等价性能。
//
// 运行命令（native 前置 `export LIBRARY_PATH=/usr/lib64:/usr/lib`）：
//   moon bench -p benches/infra_hash_bench --target native
import {
  "moonbitlang/core/bench",
  "Suquster/moonbit-pathfinding/src/infra_hash" @hash,
}
