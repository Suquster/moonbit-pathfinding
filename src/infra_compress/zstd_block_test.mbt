// zstd_block_test.mbt —— Compressed 块（FSE/Huffman）黄金向量对拍。
//
// 黄金帧由 python-zstandard 0.25.0（libzstd 参考实现）在 level 3 / 19
// 生成，覆盖：预定义分布、FSE_Compressed 表、RLE 表、Repeat 模式、
// 单流与 4 流 Huffman 字面量、RLE 字面量、重复偏移历史、XXH64 校验。
// 期望明文在测试内按同一公式重建，逐字节断言。

///|
/// 十六进制串 → 字节数组。
fn hex_bytes(s : String) -> Array[Int] {
  let out : Array[Int] = []
  let mut i = 0
  fn nib(v : Int) -> Int {
    if v >= 48 && v <= 57 {
      v - 48
    } else {
      v - 87
    }
  }

  while i + 1 < s.length() {
    out.push((nib(s[i].to_int()) << 4) | nib(s[i + 1].to_int()))
    i = i + 2
  }
  out
}

///|
/// 字符串 → 字节数组（ASCII）。
fn ascii_bytes(s : String) -> Array[Int] {
  let out : Array[Int] = []
  for i in 0..<s.length() {
    out.push(s[i].to_int() & 0xFF)
  }
  out
}

///|
test "zstd golden: level 3, 单流 Huffman + 序列（540B 重复文本）" {
  let frame = hex_bytes(
    "28b52ffd601c01bd0100c40274686520717569636b2062726f776e20666f78206a756d7073206f76657220746865206c617a7920646f672e0200e85029c0106619",
  )
  let expect : Array[Int] = []
  for _k in 0..<12 {
    for b in ascii_bytes("the quick brown fox jumps over the lazy dog. ") {
      expect.push(b)
    }
  }
  let got = @infra_compress.zstd_decompress(frame, 1 << 20)
  assert_true(got == Some(expect))
}

///|
test "zstd golden: level 19, FSE_Compressed 表 + 混合熵（1340B）" {
  let frame = hex_bytes(
    "",
  )
  let expect : Array[Int] = []
  for i in 0..<800 {
    expect.push((i * 7 + i / 5) % 251)
  }
  for _k in 0..<12 {
    for b in ascii_bytes("the quick brown fox jumps over the lazy dog. ") {
      expect.push(b)
    }
  }
  let got = @infra_compress.zstd_decompress(frame, 1 << 20)
  assert_true(got == Some(expect))
}

///|
test "zstd golden: level 3 + 校验帧（1500B 短周期模式）" {
  let frame = hex_bytes(
    "28b52ffd64dc04ed00009861626341424341424330313233343536373839020080e3f997981b0239f41d10",
  )
  let expect : Array[Int] = []
  for _k in 0..<60 {
    for b in ascii_bytes("abcabcabcABCABC0123456789") {
      expect.push(b)
    }
  }
  let got = @infra_compress.zstd_decompress(frame, 1 << 20)
  assert_true(got == Some(expect))
}

///|
test "zstd golden: level 19, 4 流 Huffman + 长序列（3130B 行文本）" {
  let frame = hex_bytes(
    "",
  )
  let expect : Array[Int] = []
  for i in 0..<120 {
    for b in ascii_bytes("line \{i}: hello zstd world\n") {
      expect.push(b)
    }
  }
  let got = @infra_compress.zstd_decompress(frame, 1 << 20)
  assert_true(got == Some(expect))
}

///|
test "zstd 畸形拒绝: 校验帧内容位翻转 → None" {
  let frame = hex_bytes(
    "28b52ffd64dc04ed00009861626341424341424330313233343536373839020080e3f997981b0239f41d10",
  )
  // 翻转字面量区一个位：熵流损坏或 XXH64 校验失败，必须显式拒绝。
  frame[14] = frame[14] ^ 0x01
  assert_true(@infra_compress.zstd_decompress(frame, 1 << 20) == None)
}

///|
test "zstd 畸形拒绝: Compressed 帧截断 → None" {
  let frame = hex_bytes(
    "28b52ffd601c01bd0100c40274686520717569636b2062726f776e20666f78206a756d7073206f76657220746865206c617a7920646f672e0200e85029c0106619",
  )
  for cut in 5..<frame.length() {
    let t : Array[Int] = []
    for k in 0..<cut {
      t.push(frame[k])
    }
    assert_true(@infra_compress.zstd_decompress(t, 1 << 20) == None)
  }
}

///|
test "zstd 解压炸弹上限: max_out 小于再生长度 → None" {
  let frame = hex_bytes(
    "28b52ffd601c01bd0100c40274686520717569636b2062726f776e20666f78206a756d7073206f76657220746865206c617a7920646f672e0200e85029c0106619",
  )
  assert_true(@infra_compress.zstd_decompress(frame, 100) == None)
}

