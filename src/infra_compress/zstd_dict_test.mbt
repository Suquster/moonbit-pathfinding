///|
test "zstd 字典帧：训练字典黄金帧解码对拍" {
  assert_true(
    @infra_compress.zstd_decompress_with_dict(zsd_frame(), zsd_dict(), 1 << 20) ==
    Some(zsd_payload()),
  )
  // 无字典入口必须拒绝 FDICT 声明帧。
  assert_true(@infra_compress.zstd_decompress(zsd_frame(), 1 << 20) == None)
}

///|
test "zstd 字典帧：裸内容字典解码对拍" {
  assert_true(
    @infra_compress.zstd_decompress_with_dict(
      zsd_raw_frame(),
      zsd_raw_dict(),
      1 << 20,
    ) ==
    Some(zsd_raw_payload()),
  )
}

///|
test "zstd 字典帧：畸形与错配拒绝" {
  // 字典 id 不匹配（改动结构化字典的 Dictionary_ID 字段）。
  let wrong_id = zsd_dict().copy()
  wrong_id[4] = wrong_id[4] ^ 0xFF
  assert_true(
    @infra_compress.zstd_decompress_with_dict(zsd_frame(), wrong_id, 1 << 20) ==
    None,
  )
  // 结构化字典截断（熵表中途截止）。
  let truncated : Array[Int] = []
  for k in 0..<16 {
    truncated.push(zsd_dict()[k])
  }
  assert_true(
    @infra_compress.zstd_decompress_with_dict(zsd_frame(), truncated, 1 << 20) ==
    None,
  )
  // 帧体损坏（尾字节翻转 → 校验/熵流失败）。
  let bad = zsd_frame().copy()
  bad[bad.length() - 1] = bad[bad.length() - 1] ^ 0xFF
  assert_true(
    @infra_compress.zstd_decompress_with_dict(bad, zsd_dict(), 1 << 20) == None,
  )
  // 普通无字典帧走字典入口仍可解（FDICT 未声明不强制）。
  let plain = @infra_compress.zstd_compress(zsd_payload(), true)
  assert_true(
    @infra_compress.zstd_decompress_with_dict(plain, zsd_dict(), 1 << 20) ==
    Some(zsd_payload()),
  )
}
