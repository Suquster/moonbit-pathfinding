// Package: Suquster/moonbit-pathfinding/src/proofs
//
// Hosts shared mathematical predicates plus per-algorithm `*_proof.mbt`
// files that form the scaffolding for `moon prove` integration
// (tasks.md Milestone 4, requirements R8).
//
// Import convention:
//   * `@core` — for `Weight` trait / `PathError` enum referenced in
//     cost & error-typed predicates.
import {
  "Suquster/moonbit-pathfinding/src/core",
  "Suquster/moonbit-pathfinding/src/infra_text",
}

// 属性测试（任务 10.2 起的 Property 11 等谓词性质）复用共享 PBT 包 @infra_pbt
// 的 Gen / Rng / holds_for_all 模板（每条属性 ≥100 次迭代）。该依赖仅作用于
// 黑盒测试驱动（`for "test"`），不进入运行时产物，符合 design.md「infra_pbt
// 为横切测试期共享约定」的定位，保持 proofs 生产代码仅依赖 @core / @infra_text。
import {
  "Suquster/moonbit-pathfinding/src/infra_pbt",
  "Suquster/moonbit-pathfinding/src/docgen",
  "Suquster/moonbit-pathfinding/src/evidence_index",
  "Suquster/moonbit-pathfinding/src/mooncakes_audit",
  "Suquster/moonbit-pathfinding/src/release_meta",
  "Suquster/moonbit-pathfinding/src/graph",
  "Suquster/moonbit-pathfinding/src/infra_alloc",
  "Suquster/moonbit-pathfinding/src/infra_bench",
  "Suquster/moonbit-pathfinding/src/infra_fuzz",
  "Suquster/moonbit-pathfinding/src/infra_cli",
  "Suquster/moonbit-pathfinding/src/infra_codec",
  "Suquster/moonbit-pathfinding/src/infra_config",
  "Suquster/moonbit-pathfinding/src/infra_compress",
  "Suquster/moonbit-pathfinding/src/infra_diff",
  "Suquster/moonbit-pathfinding/src/infra_ds",
  "Suquster/moonbit-pathfinding/src/infra_hash",
  "Suquster/moonbit-pathfinding/src/infra_metrics",
  "Suquster/moonbit-pathfinding/src/infra_time",
  "Suquster/moonbit-pathfinding/src/infra_resilience",
  "Suquster/moonbit-pathfinding/src/infra_timer",
  "Suquster/moonbit-pathfinding/src/regex_engine",
  "moonbitlang/core/debug",
  "moonbitlang/core/test",
} for "test"

options(
  "proof-enabled": true,
)
