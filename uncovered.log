 42	pub fn[N : Eq + Hash] bfs(
 43	  start : N,
 44	  successors : (N) -> Array[N],
 45	  goal : (N) -> Bool,
 46	) -> Array[N]? {
 47	  if goal(start) {
 48	    return Some([start])
 49	  }
 50	  let queue : Array[N] = [start]
 51	  let parents : Map[N, N] = Map([])
 52	  let visited : Map[N, Bool] = Map([])
 53	  visited[start] = true
 54	  let mut head = 0
 55	  //
 56	  // Loop invariant (R8.1 / R8.4 · tasks.md 33.3 · target of `moon prove`):
 57	  //
 58	  //   (I1) Queue-visited consistency:
 59	  //          forall n in queue[head..], visited.contains(n) == true
 60	  //        — every node still pending expansion has been recorded in
 61	  //        `visited`, so BFS never enqueues the same node twice.
 62	  //
 63	  //   (I2) Parent-well-formedness:
 64	  //          forall n with parents[n] = p, visited.contains(p)
 65	  //        — each parent pointer points to a node that was expanded
 66	  //        earlier, which guarantees the reconstructed path ends at `start`.
 67	  //
 68	  //   (I3) Visited-Root coverage:
 69	  //          forall n in visited, n == start \/ parents.contains(n)
 70	  //        — every visited node except `start` has a recorded parent,
 71	  //        so path reconstruction terminates at `start` rather than
 72	  //        looping forever.
 73	  //
 74	  //   (I4) BFS level monotonicity (shortest-path witness):
 75	  //          for any n reached at step i, depth(n) <= i
 76	  //        — expressed informally as "the parent-chain length of every
 77	  //        node in `visited` is bounded by `queue[0..head]` length";
 78	  //        this is the heart of the "BFS returns a shortest unweighted
 79	  //        path" theorem, discharged by induction on `head`.
 80	  //
 81	  //   (I5) No revisit on discovery:
 82	  //          `visited.contains(next)` is always checked before enqueue,
 83	  //        so the reachable subgraph is traversed at most once.
