104	pub fn run_tco_with_depth(bc : Bytecode, env : Env) -> (Val, Int) {
105	  let vm = VM::{ stack: [], frames: [] }
106	  vm.frames.push(Frame::{ bc, pc: 0, env: senv_of_env(env) })
107	  let mut max_depth = vm.frames.length()
108	  while vm.frames.length() > 0 {
109	    if vm.frames.length() > max_depth {
110	      max_depth = vm.frames.length()
111	    }
112	    let frame = vm.frames[vm.frames.length() - 1]
113	    // 当前帧字节码耗尽：顶层结束则退出；否则弹出该帧回到调用者。
114	    if frame.pc >= frame.bc.instrs.length() {
115	      if vm.frames.length() == 1 {
116	        break
117	      }
118	      vm.frames.pop() |> ignore
119	      continue
120	    }
121	    let instr = frame.bc.instrs[frame.pc]
122	    match instr {
123	      PushInt(n) => {
124	        vm.stack.push(SInt(n))
125	        frame.pc += 1
126	      }
127	      PushBool(b) => {
128	        vm.stack.push(SBool(b))
129	        frame.pc += 1
130	      }
131	      LoadVar(x) => {
132	        vm.stack.push(senv_lookup(frame.env, x))
133	        frame.pc += 1
134	      }
135	      Arith(op) => {
136	        let b = sval_int(pop_s(vm.stack))
137	        let a = sval_int(pop_s(vm.stack))
138	        vm.stack.push(SInt(ml_apply_arith(op, a, b)))
139	        frame.pc += 1
140	      }
141	      Cmp(op) => {
