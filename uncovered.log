 28	pub fn[L, R : Eq + Hash] hopcroft_karp(
 29	  left : Array[L],
 30	  right : Array[R],
 31	  neighbors : (L) -> Array[R],
 32	) -> Array[(L, R)] {
 33	  let nl = left.length()
 34	  let nr = right.length()
 35	  let rindex : Map[R, Int] = Map([])
 36	  for j in 0..<nr {
 37	    rindex[right[j]] = j
 38	  }
 39	  // Pre-resolve adjacency to integer indices once.
 40	  let adj : Array[Array[Int]] = Array::makei(nl, fn(i) {
 41	    let lst : Array[Int] = []
 42	    for r in neighbors(left[i]) {
 43	      match rindex.get(r) {
 44	        Some(j) => lst.push(j)
 45	        None => ()
 46	      }
 47	    }
 48	    lst
 49	  })
 50	  // match_l[i] = right index matched to left i (-1 if free), and vice versa.
 51	  let match_l : Array[Int] = Array::make(nl, -1)
 52	  let match_r : Array[Int] = Array::make(nr, -1)
 53	  let level : Array[Int] = Array::make(nl, HK_INF)
 54	  fn bfs() -> Bool {
 55	    let queue : Array[Int] = []
 56	    for i in 0..<nl {
 57	      if match_l[i] < 0 {
 58	        level[i] = 0
 59	        queue.push(i)
 60	      } else {
 61	        level[i] = HK_INF
 62	      }
 63	    }
 64	    let mut found = false
 65	    let mut head = 0
 66	    while head < queue.length() {
 67	      let u = queue[head]
 68	      head += 1
 69	      for j in adj[u] {
 70	        let w = match_r[j]
 71	        if w < 0 {
 72	          found = true
 73	        } else if level[w] == HK_INF {
 74	          level[w] = level[u] + 1
 75	          queue.push(w)
 76	        }
 77	      }
 78	    }
 79	    found
 80	  }
 81	
 82	  // Iterative augmenting-path search with an explicit call stack, mirroring
 83	  // the recursive DFS exactly but without risking native-stack overflow on
 84	  // long alternating paths (which can reach depth O(V) on large graphs).
 85	  // This matches the codebase convention of keeping graph DFS non-recursive
 86	  // (cf. `tarjan_scc`, `directed/dfs`).
 87	  //
 88	  // Each frame is `cs_node[k]` (a left vertex) with `cs_pos[k]` its current
 89	  // scan offset into `adj`. `cs_j[k]` records the right vertex chosen to
 90	  // descend from frame `k` to frame `k+1`; on success the whole alternating
 91	  // path is re-matched in one upward pass.
 92	  let cs_node : Array[Int] = []
 93	  let cs_pos : Array[Int] = []
 94	  let cs_j : Array[Int] = []
 95	  fn dfs(u0 : Int) -> Bool {
 96	    cs_node.clear()
 97	    cs_pos.clear()
 98	    cs_j.clear()
 99	    cs_node.push(u0)
100	    cs_pos.push(0)
101	    while cs_node.length() > 0 {
102	      let top = cs_node.length() - 1
103	      let u = cs_node[top]
104	      let mut advanced = false
105	      while cs_pos[top] < adj[u].length() {
106	        let j = adj[u][cs_pos[top]]
107	        cs_pos[top] += 1
108	        let w = match_r[j]
109	        if w < 0 {
110	          // Free right vertex reached: augment along the whole path.
111	          match_l[u] = j
112	          match_r[j] = u
113	          let mut k = top - 1
114	          while k >= 0 {
115	            match_l[cs_node[k]] = cs_j[k]
116	            match_r[cs_j[k]] = cs_node[k]
117	            k -= 1
118	          }
119	          return true
120	        } else if level[w] == level[u] + 1 {
121	          cs_j.push(j)
122	          cs_node.push(w)
123	          cs_pos.push(0)
124	          advanced = true
125	          break
126	        }
127	      }
128	      if !advanced {
129	        // `u` exhausted with no augmenting edge: mark dead and backtrack.
130	        level[u] = HK_INF
131	        ignore(cs_node.pop())
132	        ignore(cs_pos.pop())
133	        if cs_node.length() > 0 {
