273	  lm : Landmark[N, W],
274	  start : N,
275	  goal : N,
276	  successors : (N) -> Array[(N, W)],
277	) -> (Array[N], W)? {
278	  if start == goal {
279	    return Some(([start], @core.Weight::zero()))
280	  }
