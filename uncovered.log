130	    return lens
131	  }
132	  if active.length() == 1 {
133	    lens[active[0]] = 1
134	    return lens
135	  }
136	  // 朴素 O(k²) 霍夫曼合并（k ≤ 288，规模可控）：
137	  // node = (weight, 由哪些符号组成)。每个符号深度 = 参与合并次数。
138	  let weights : Array[Int] = []
139	  let members : Array[Array[Int]] = []
140	  for s in active {
141	    weights.push(freqs[s])
142	    members.push([s])
143	  }
144	  let alive : Array[Bool] = Array::make(weights.length() * 2, true)
145	  let mut count = weights.length()
146	  while count > 1 {
