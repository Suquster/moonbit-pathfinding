346	    let tmp = clist
347	    clist = nlist
348	    nlist = tmp
349	    nlist.reset()
350	    if pos >= n {
351	      break
352	    }
353	    match matched {
354	      Some(_) => if clist.pcs.length() == 0 { break }
355	      None => ()
356	    }
357	    pos = pos + 1
358	  }
