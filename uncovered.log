267	pub fn[N : Eq + Hash, W : @core.Weight + Compare] ch_preprocess(
268	  nodes : Array[N],
269	  successors : (N) -> Array[(N, W)],
270	) -> CHGraph[N, W] {
271	  let level : Map[N, Int] = Map([])
272	  let shortcut : Map[(N, N), N] = Map([])
273	  let (residual, rev_residual) = ch_init_residual(nodes, successors)
274	  let contracted : Map[N, Bool] = Map([])
275	  // Edge-difference estimate for contraction ordering: the number of
276	  // potential shortcuts (in-degree x out-degree among uncontracted
277	  // neighbours) minus the number of incident residual edges. Smaller
278	  // values contract first; estimates are re-evaluated lazily on pop.
279	  fn edge_difference(v : N) -> Int {
280	    let mut in_deg = 0
281	    for e in rev_residual.get(v).unwrap_or([]) {
282	      if !contracted.get(e.0).unwrap_or(false) && e.0 != v {
283	        in_deg += 1
284	      }
285	    }
286	    let mut out_deg = 0
287	    for e in residual.get(v).unwrap_or([]) {
288	      if !contracted.get(e.0).unwrap_or(false) && e.0 != v {
289	        out_deg += 1
290	      }
291	    }
292	    in_deg * out_deg - (in_deg + out_deg)
293	  }
294	
295	  let order : @core.PQueue[N, Int] = @core.PQueue::new()
296	  for n in nodes {
297	    order.push(edge_difference(n), n)
298	  }
299	  let mut next_level = 0
300	  while !order.is_empty() {
301	    let (prio, v) = order.pop().unwrap()
302	    if contracted.get(v).unwrap_or(false) {
303	      continue	<-- UNCOVERED
304	    }
305	    // Lazy re-evaluation: contracting earlier nodes may have changed this
306	    // node's edge difference; if it grew, push it back and pick again.
307	    let fresh = edge_difference(v)
308	    if fresh > prio && !order.is_empty() {
309	      order.push(fresh, v)
310	      continue
311	    }
312	    level[v] = next_level
313	    next_level += 1
314	    ch_contract_node(v, residual, rev_residual, contracted, shortcut)
315	  }
316	  // Build upward / downward adjacency from the final residual graph.
317	  let (up_adj, dn_adj) = ch_build_adjacency(nodes, level, residual)
318	  { nodes, level, up_adj, dn_adj, shortcut }
319	}
