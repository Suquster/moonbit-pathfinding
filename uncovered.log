215	pub fn[N : Eq + Hash] typed_bfs_path(
216	  nodes : Array[N],
217	  source : N,
218	  target : N,
219	  successors : (N) -> Array[N],
220	) -> Result[(Array[N], Int), PathError] {
221	  // —— 阶段一：参数与端点合法性校验（只读，不修改输入 · R13.2/13.3/13.6）。 ——
222	  if nodes.length() == 0 {
223	    return Err(InvalidArgument(empty_nodes_message()))
224	  }
225	  let in_graph : Map[N, Unit] = Map([])
226	  for n in nodes {
227	    in_graph[n] = ()
228	  }
229	  if !(in_graph.get(source) is Some(_)) {
230	    return Err(SourceNotFound)
231	  }
232	  if !(in_graph.get(target) is Some(_)) {
233	    return Err(TargetNotFound)
234	  }
235	  // —— 阶段二：BFS 逐层扩展，记录前驱用于回溯。 ——
236	  let pred : Map[N, N] = Map([])
237	  let visited : Map[N, Unit] = Map([])
238	  let queue : Array[N] = [source]
239	  visited[source] = ()
240	  let mut head = 0
241	  let mut found = false
242	  while head < queue.length() {
243	    let cur = queue[head]
244	    head = head + 1
245	    if cur == target {
246	      found = true
247	      break
248	    }
249	    for v in successors(cur) {
250	      if in_graph.get(v) is Some(_) && !(visited.get(v) is Some(_)) {
251	        visited[v] = ()
252	        pred[v] = cur
253	        queue.push(v)
254	      }
255	    }
256	  }
257	  if !found {
258	    return Err(Unreachable)
259	  }
260	  // —— 阶段三：自 target 回溯到 source，翻转得到正序路径。 ——
261	  let chain : Array[N] = [target]
262	  let mut cur = target
263	  while cur != source {
264	    match pred.get(cur) {
265	      Some(p) => {
266	        chain.push(p)
267	        cur = p
268	      }
269	      None => break	<-- UNCOVERED
270	    }
271	  }
272	  let path : Array[N] = []
273	  for i = chain.length() - 1; i >= 0; i = i - 1 {
274	    path.push(chain[i])
275	  }
276	  Ok((path, path.length() - 1))
277	}
