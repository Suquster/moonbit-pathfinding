133	    TEBool(b, _, _) => out.push(PushBool(b))
134	    // 变量：从当前帧环境取值。
135	    TEVar(x, _, _) => out.push(LoadVar(x))
136	    // 二元算术 / 比较 / 逻辑：先左后右，再运算（右在栈顶）。
137	    TEArith(op, l, r, _, _) => {
138	      emit(l, out)
139	      emit(r, out)
140	      out.push(Arith(op))
141	    }
142	    TECmp(op, l, r, _, _) => {
143	      emit(l, out)
144	      emit(r, out)
145	      out.push(Cmp(op))
146	    }
147	    TELogic(op, l, r, _, _) => {
148	      emit(l, out)
149	      emit(r, out)
150	      out.push(Logic(op))
151	    }
152	    // 条件：绝对索引回填。
153	    //   emit(c); JumpIfFalse(else_start); emit(then); Jump(end); <else_start> emit(else); <end>
154	    TEIf(c, a, b, _, _) => {
155	      emit(c, out)
156	      let jf = out.length()
157	      out.push(JumpIfFalse(0)) // 占位，稍后回填为 else 分支起点
158	      emit(a, out)
