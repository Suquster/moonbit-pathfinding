315	      let (v, w) = pair
316	      let tentative = @core.Weight::add(gu, w)
317	      let improve = match g_cost.get(v) {
318	        Some(cur) => tentative < cur
319	        None => true
320	      }
321	      if improve {
322	        g_cost[v] = tentative
323	        parents[v] = u
324	        let f = @core.Weight::add(tentative, alt_heuristic(lm, v, goal))
