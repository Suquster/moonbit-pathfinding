151	fn exec_simple(
152	  regs : Map[Int, Int],
153	  memory : Map[Int, Int],
154	  prev : String?,
155	  ins : TypedInstr,
156	) -> Unit {
157	  match ins {
158	    Add(dst~, lhs~, rhs~) =>
159	      regs[dst] = eval_value(regs, memory, lhs) + eval_value(regs, memory, rhs)
160	    Sub(dst~, lhs~, rhs~) =>
161	      regs[dst] = eval_value(regs, memory, lhs) - eval_value(regs, memory, rhs)
