155	              // Deduplicate.
156	              let mut dup = false
157	              for c in candidates {
158	                if c.0 == full {
159	                  dup = true
160	                  break
161	                }
162	              }
163	              if !dup {
164	                candidates.push((full, total))
165	              }
166	            }
167	            None => ()
168	          }
169	          i += 1
170	        }
171	        if candidates.length() == 0 {
172	          break
173	        }
174	        // Pick the cheapest candidate via a single linear scan (O(C)) rather
175	        // than re-sorting the whole growing candidate list every iteration
176	        // (which would be O(C log C) per round). Ties keep the earliest
177	        // candidate for deterministic output.
178	        let mut best_idx = 0
