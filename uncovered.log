143	        let a = sval_int(pop_s(vm.stack))
144	        vm.stack.push(SBool(ml_apply_cmp(op, a, b)))
145	        frame.pc += 1
146	      }
147	      Logic(op) => {
148	        let b = sval_bool(pop_s(vm.stack))
149	        let a = sval_bool(pop_s(vm.stack))
150	        vm.stack.push(
151	          SBool(
152	            match op {
153	              And => a && b
154	              Or => a || b
155	            },
156	          ),
157	        )
158	        frame.pc += 1
159	      }
160	      JumpIfFalse(t) => {
161	        let c = sval_bool(pop_s(vm.stack))
162	        if c {
