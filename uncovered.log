 24	pub fn[N : Eq + Hash, W : @core.Weight + Compare] yen_k_shortest(
 25	  start : N,
 26	  goal : N,
 27	  edges : Array[(N, N, W)],
 28	  k : Int,
 29	) -> Result[Array[(Array[N], W)], @core.PathError] {
 30	  if k <= 0 {
 31	    return Err(InvalidK(k))
 32	  }
 33	  // Prebuild adjacency once: O(E) total instead of O(E) per successor call.
 34	  let adj : Map[N, Array[(N, W)]] = Map([])
 35	  let edge_weight : Map[(N, N), W] = Map([])
 36	  for e in edges {
 37	    let (a, b, w) = e
 38	    let lst = adj.get(a).unwrap_or([])
 39	    lst.push((b, w))
 40	    adj[a] = lst
 41	    // Keep the cheapest weight in case of parallel edges.
 42	    match edge_weight.get((a, b)) {
 43	      Some(existing) => if w < existing { edge_weight[(a, b)] = w }
 44	      None => edge_weight[(a, b)] = w
 45	    }
 46	  }
 47	  // Build successor function that respects banned edges/nodes via O(1)
 48	  // hash lookups.
 49	  fn build_succ(
 50	    banned_edges : Map[(N, N), Bool],
 51	    banned_nodes : Map[N, Bool],
 52	  ) -> (N) -> Array[(N, W)] {
 53	    fn(u : N) -> Array[(N, W)] {
 54	      let result : Array[(N, W)] = []
 55	      for pair in adj.get(u).unwrap_or([]) {
 56	        let (b, w) = pair
 57	        if banned_edges.get((u, b)).unwrap_or(false) {
 58	          continue
 59	        }
 60	        if banned_nodes.get(b).unwrap_or(false) {
 61	          continue
 62	        }
 63	        result.push((b, w))
 64	      }
 65	      result
 66	    }
 67	  }
 68	
 69	  // First shortest path (A = [shortest]).
 70	  let first = dijkstra(start, build_succ(Map([]), Map([])), fn(n) { n == goal })
 71	  match first {
 72	    None => return Ok([])
 73	    Some(p_and_c) => {
 74	      let accepted : Array[(Array[N], W)] = [p_and_c]
 75	      let candidates : Array[(Array[N], W)] = []
 76	      let mut ki = 1
 77	      //
 78	      // 循环不变式（R10.1 · Yen K-最短路主循环 · 谓词见 @proofs.yen_post）:
 79	      //
 80	      //   (布尔陈述) accepted 恰为按代价非降排列的前 ki 条无环 s-t 路径，且互不相同；
 81	      //       candidates 是「以某 accepted 路径前缀为根、在被禁边/禁点约束下经 Dijkstra
 82	      //       求得」的待选偏离路径池，其中任一候选代价不小于已接受路径的末条。
 83	      //
 84	      //   (初始化成立) 进入循环前 ki=1，accepted=[最短路]，candidates=[]：单条最短路
 85	      //       平凡有序且无环；空候选池平凡满足下界条件。
 86	      //
 87	      //   (迭代保持) 对第 ki-1 条路径的每个 spur 节点，禁掉「与已接受路径共享根前缀」的
 88	      //       后继边及根上其余节点（保证无环），用 Dijkstra 求 spur→goal，与根前缀拼接、
 89	      //       去重后入 candidates。随后线性扫描取代价最小的候选加入 accepted、移出候选池，
 90	      //       ki 递增：新接受路径代价不小于上一条（候选下界 + 取最小），故 accepted 始终
 91	      //       有序。候选池空则提前结束。最多产出 k 条，循环终止。
 92	      //
 93	      while ki < k {
 94	        let prev_path = accepted[ki - 1].0
 95	        let mut i = 0
 96	        while i < prev_path.length() - 1 {
 97	          let spur_node = prev_path[i]
 98	          let root_path = prev_path[0:i + 1].iter().collect()
 99	          // Build banned edges: edges used at position i by any accepted
100	          // path sharing this root prefix.
101	          let banned_edges : Map[(N, N), Bool] = Map([])
102	          for acc in accepted {
103	            let ap = acc.0
104	            if ap.length() > i + 1 {
105	              let mut matches = true
106	              let mut j = 0
107	              while j <= i && matches {
108	                if ap[j] != prev_path[j] {
109	                  matches = false
110	                }
111	                j += 1
112	              }
113	              if matches {
114	                banned_edges[(ap[i], ap[i + 1])] = true
115	              }
116	            }
117	          }
118	          // Ban root path nodes (except spur_node) to keep paths loopless.
119	          let banned_nodes : Map[N, Bool] = Map([])
120	          for rn in root_path {
121	            if rn != spur_node {
122	              banned_nodes[rn] = true
123	            }
124	          }
125	          let spur = dijkstra(
126	            spur_node,
127	            build_succ(banned_edges, banned_nodes),
128	            fn(n) { n == goal },
129	          )
