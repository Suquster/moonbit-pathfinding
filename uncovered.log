 34	pub fn lex_ml(src : String) -> Result[Array[MlToken], Diagnostic] {
 35	  let tokens : Array[MlToken] = []
 36	  let mut cur = @pc.Input::from_string(src)
 37	  while !cur.is_eof() {
 38	    let c = match cur.peek() {
 39	      Some(ch) => ch
 40	      None => break	<-- UNCOVERED
 41	    }
 42	    // 每个 token 的 span 锚定到其起始字符的行列（1 起始）。
 43	    let span = Span::{ line: cur.pos.line, col: cur.pos.col }
 44	    if is_space(c) {
 45	      cur = cur.advance()
 46	    } else if is_digit(c) {
 47	      let (n, rest) = scan_int(cur)
 48	      tokens.push(TkInt(n, span))
 49	      cur = rest
 50	    } else if is_alpha(c) {
 51	      let (name, rest) = scan_ident(cur)
 52	      tokens.push(classify_ident(name, span))
 53	      cur = rest
 54	    } else {
 55	      // 算符 / 括号：对可起多字符算符的前导字符做最长匹配（peek 下一字符）。
 56	      let next = cur.advance().peek()
 57	      match c {
 58	        '+' => {
 59	          tokens.push(TkOp("+", span))
 60	          cur = cur.advance()
 61	        }
