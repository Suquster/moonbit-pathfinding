282	fn Program::exec_chars(
283	  self : Program,
284	  chars : Array[Char],
285	  n : Int,
286	  start : Int,
287	  kind : MatchKind,
288	) -> Captures? {
289	  let ninst = self.insts.length()
290	  let slots_len = 2 * (self.num_groups + 1)
291	  let mut clist = ThreadList::new(ninst)
292	  let mut nlist = ThreadList::new(ninst)
293	  let mut matched : Array[Int]? = None
294	  let mut pos = start
295	  while true {
296	    // 字面量预过滤（T2.1）：仅当存在首字符集预过滤、尚未命中、且无在飞线程时，
297	    // 把 pos 跳到下一个可能成为匹配起点的位置。此条件下跳过中间位置不会丢弃
298	    // 任何匹配中途的线程，故 `find`/`find_all`/`is_match` 结果与不过滤逐位相等。
299	    // 非可空正则若再无候选起点（np >= n），则不可能再有匹配，提前终止。
300	    match self.prefilter {
301	      PfNone => ()
302	      PfFirstSet(_) | PfLiterals(_) =>
303	        if matched is None && clist.pcs.length() == 0 {
304	          let np = self.prefilter.next_candidate(chars, n, pos)
305	          if np >= n {
306	            break
307	          }
308	          pos = np
309	        }
310	    }
311	    // 在每个位置追加最低优先级起点线程，实现单遍最左扫描；命中后停止播种。
312	    match matched {
313	      None => {
314	        let init = Array::make(slots_len, -1)
315	        self.add_thread(clist, 0, init, chars, n, pos)
316	      }
317	      Some(_) => ()
318	    }
319	    let mut i = 0
320	    while i < clist.pcs.length() {
321	      let pc = clist.pcs[i]
322	      let saved = clist.saveds[i]
323	      match self.insts[pc] {
324	        IChar(ch) =>
325	          if pos < n && chars[pos] == ch {
326	            self.add_thread(nlist, pc + 1, saved, chars, n, pos + 1)
327	          }
328	        ISet(cs) =>
329	          if pos < n && cs.contains(chars[pos].to_int()) {
330	            self.add_thread(nlist, pc + 1, saved, chars, n, pos + 1)
331	          }
