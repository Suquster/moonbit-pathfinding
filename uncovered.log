286	  pq.push(alt_heuristic(lm, start, goal), start)
287	  while !pq.is_empty() {
288	    let (_, u) = pq.pop().unwrap()
289	    // Skip stale entries: if g_cost[u] has been improved since this push,
290	    // this pop is outdated. This is the standard "lazy deletion" pattern
291	    // used by Dijkstra; combined with an admissible heuristic it guarantees
292	    // that when we pop goal, g_cost[goal] is optimal — so we can stop there
293	    // instead of exhausting the whole queue.
