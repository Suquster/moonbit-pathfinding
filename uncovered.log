 24	pub fn myers_diff(a : String, b : String) -> Array[DiffOp] {
 25	  let n = a.length()
 26	  let m = b.length()
 27	  if n == 0 && m == 0 {
 28	    return []
 29	  }
 30	  if n == 0 {
 31	    return [Insert(b)]
 32	  }
 33	  if m == 0 {
 34	    return [Delete(a)]
 35	  }
 36	  let max_d = n + m
 37	  let offset = max_d
 38	  // V[k + offset] = 对角线 k 上 furthest-reaching 的 x。
 39	  let v : Array[Int] = Array::make(2 * max_d + 1, 0)
 40	  // 每层 d 的 V 快照（回溯用）。
 41	  let trace : Array[Array[Int]] = []
 42	  let mut found_d = -1
 43	  for d in 0..<=max_d {
 44	    let mut k = -d
 45	    while k <= d {
 46	      let idx = k + offset
 47	      let mut x = if k == -d || (k != d && v[idx - 1] < v[idx + 1]) {
 48	        v[idx + 1] // 向下（插入 b 的一个码元）
 49	      } else {
 50	        v[idx - 1] + 1 // 向右（删除 a 的一个码元）
 51	      }
 52	      let mut y = x - k
 53	      // 贪心沿蛇形（公共段）滑行。
 54	      while x < n && y < m && a.at(x) == b.at(y) {
 55	        x = x + 1
 56	        y = y + 1
 57	      }
 58	      v[idx] = x
 59	      if x >= n && y >= m {
 60	        found_d = d
 61	        break
 62	      }
 63	      k = k + 2
 64	    }
 65	    trace.push(v.copy())
 66	    if found_d >= 0 {
 67	      break
 68	    }
 69	  }
 70	  // 回溯：从 (n, m) 沿快照逐层还原路径，先收集反向操作序列。
 71	  // rev_ops 项：(op, len)，op ∈ {0=Equal, 1=Delete(a), 2=Insert(b)}，
 72	  // 附带片段在源串中的终点，最后统一物化子串。
 73	  let ops : Array[DiffOp] = []
 74	  let mut x = n
 75	  let mut y = m
 76	  let rev : Array[(Int, Int, Int)] = [] // (op, x_end, len)
 77	  let mut d = found_d
 78	  while d > 0 {
 79	    let vd = trace[d - 1]
 80	    let k = x - y
 81	    let (prev_k, down) = if k == -d ||
 82	      (k != d && vd[k - 1 + offset] < vd[k + 1 + offset]) {
 83	      (k + 1, true) // 来自向下一步（Insert）
 84	    } else {
 85	      (k - 1, false) // 来自向右一步（Delete）
 86	    }
 87	    let prev_x = vd[prev_k + offset]
 88	    let prev_y = prev_x - prev_k
 89	    // 蛇形公共段。
 90	    let mid_x = if down { prev_x } else { prev_x + 1 }
 91	    let mid_y = if down { prev_y + 1 } else { prev_y }
 92	    if x > mid_x {
 93	      rev.push((0, x, x - mid_x)) // Equal，a 的 [mid_x, x)
 94	    }
 95	    if down {
 96	      rev.push((2, mid_y, 1)) // Insert，b 的 [prev_y, mid_y)
 97	    } else {
